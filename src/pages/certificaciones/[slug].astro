---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import { BadgeCheck, ExternalLink, ArrowLeft, Calendar } from 'lucide-react';
import { profile } from '../../data/profile';
import { asset } from '../../lib/asset';

// getStaticPaths mapea cada certificación a /certificaciones/{slug}/.
export async function getStaticPaths() {
  const certs = await getCollection('certifications');
  return certs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const c = entry.data;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeUrl = new URL(`${base}/`, Astro.site).toString();
const certsHub = new URL(`${base}/certificaciones/`, Astro.site).toString();
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const issued = c.issueDate.toISOString().slice(0, 10);
const fmtDate = (d: Date) => d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

// JSON-LD: EducationalOccupationalCredential (la certificación) + BreadcrumbList.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'EducationalOccupationalCredential',
      '@id': `${pageUrl}#credential`,
      name: c.name,
      description: c.summary ?? undefined,
      url: pageUrl,
      credentialCategory: 'certification',
      dateCreated: issued,
      recognizedBy: { '@type': 'EducationalOrganization', name: c.institution },
      ...(c.credentialUrl ? { identifier: c.credentialUrl } : {}),
      ...(c.topics.length ? { competencyRequired: c.topics.join(', ') } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: homeUrl },
        { '@type': 'ListItem', position: 2, name: 'Certificaciones', item: certsHub },
        { '@type': 'ListItem', position: 3, name: c.name, item: pageUrl },
      ],
    },
  ],
};
---

<Layout
  title={`${c.name} — ${profile.shortName}`}
  description={c.summary ?? `${c.name} · ${c.institution}`}
  ogImage={asset(c.logo)}
  ogType="article"
  publishedTime={issued}
  articleTags={[c.institution, ...(c.specialization ? [c.specialization] : []), ...c.topics]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main id="main" class="mx-auto max-w-4xl px-6 py-32 xl:max-w-5xl">
    <nav aria-label="Migas de pan" class="reveal-item is-visible mb-6">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-(--color-muted)">
        <li><a href={`${base}/`} class="hover:text-(--color-accent)">Inicio</a></li>
        <li aria-hidden="true">/</li>
        <li><a href={`${base}/certificaciones/`} class="hover:text-(--color-accent)">Certificaciones</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-(--color-fg)" aria-current="page">{c.name}</li>
      </ol>
    </nav>

    <article>
      <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start">
        <img
          src={asset(c.logo)}
          alt={`Logo de ${c.institution}`}
          width={56}
          height={56}
          class="reveal-item is-visible h-14 w-14 shrink-0 rounded-xl"
        />
        <div class="min-w-0">
          <h1 class="reveal-item is-visible flex items-start gap-1.5 font-display text-2xl font-bold tracking-tight text-(--color-fg) sm:text-3xl xl:text-4xl">
            <span class="flex-1">{c.name}</span>
            <BadgeCheck className="mt-1 h-5 w-5 shrink-0 text-(--color-accent)" />
          </h1>
          <p class="reveal-item is-visible mt-1 text-sm text-(--color-muted)">
            {c.institution} · {fmtDate(c.issueDate)}
          </p>
          {c.specialization && (
            <p class="reveal-item is-visible mt-2 text-sm font-medium text-(--color-accent)">
              {c.specialization}
            </p>
          )}
        </div>
      </header>

      {c.credentialUrl && (
        <a
          href={c.credentialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="reveal-item is-visible inline-flex items-center gap-1.5 rounded-full glass-pill px-4 py-2 text-sm font-medium text-(--color-accent) transition hover:-translate-y-0.5"
        >
          <ExternalLink className="h-4 w-4" /> Ver credencial
        </a>
      )}

      {c.topics.length > 0 && (
        <ul class="reveal-item is-visible mt-6 flex flex-wrap gap-2">
          {c.topics.map((t) => (
            <li class="rounded-full bg-(--color-bg) px-2.5 py-1 text-xs font-medium text-(--color-muted) ring-1 ring-(--color-border)">
              {t}
            </li>
          ))}
        </ul>
      )}

      <div
        class="prose-project reveal-item is-visible mt-10 max-w-none text-base leading-relaxed text-(--color-muted)"
      >
        <Content />
      </div>
    </article>

    <div class="mt-12 flex flex-wrap gap-4">
      <a
        href={`${base}/certificaciones/`}
        class="inline-flex items-center gap-2 rounded-full glass-pill px-5 py-2.5 text-sm font-medium text-(--color-fg) transition hover:-translate-y-0.5 hover:text-(--color-accent)"
      >
        <ArrowLeft className="h-4 w-4" /> Ver todas las certificaciones
      </a>
    </div>
  </main>

  <Ticker
    items={['Deep Learning', 'DeepLearning.AI', 'Redes Neuronales', 'Transformers', 'IA Generativa']}
    duration={32}
    solid
    class="mb-16"
  />
</Layout>