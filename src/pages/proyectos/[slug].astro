---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Ticker from '../../components/Ticker.astro';
import { Code2, ExternalLink, ArrowLeft, Calendar } from 'lucide-react';
import { profile } from '../../data/profile';
import { asset } from '../../lib/asset';

// getStaticPaths mapea cada proyecto a /proyectos/{slug}/ (trailingSlash siempre).
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const p = entry.data;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeUrl = new URL(`${base}/`, Astro.site).toString();
const proyectosHub = new URL(`${base}/proyectos/`, Astro.site).toString();
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const published = p.pubDate.toISOString().slice(0, 10);
const fmtDate = (d: Date) => d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

// JSON-LD de la página: CreativeWork (el proyecto) + BreadcrumbList.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CreativeWork',
      '@id': `${pageUrl}#project`,
      name: p.title,
      description: p.summary ?? p.description,
      url: pageUrl,
      image: new URL(asset(p.coverImage), Astro.site).toString(),
      author: { '@id': `${homeUrl}#person` },
      datePublished: published,
      keywords: p.technologies.join(', '),
      ...(p.githubUrl ? { codeRepository: p.githubUrl } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: homeUrl },
        { '@type': 'ListItem', position: 2, name: 'Proyectos', item: proyectosHub },
        { '@type': 'ListItem', position: 3, name: p.title, item: pageUrl },
      ],
    },
  ],
};
---

<Layout
  title={`${p.title} — ${profile.shortName}`}
  description={p.summary ?? p.description}
  ogImage={asset(p.coverImage)}
  ogType="article"
  publishedTime={published}
  articleTags={p.technologies}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main id="main" class="mx-auto max-w-4xl px-6 py-32 xl:max-w-5xl">
    {/* Breadcrumb visible + volver */}
    <nav aria-label="Migas de pan" class="reveal-item is-visible mb-6">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-(--color-muted)">
        <li><a href={`${base}/`} class="hover:text-(--color-accent)">Inicio</a></li>
        <li aria-hidden="true">/</li>
        <li><a href={`${base}/proyectos/`} class="hover:text-(--color-accent)">Proyectos</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-(--color-fg)" aria-current="page">{p.title}</li>
      </ol>
    </nav>

    <article>
      <header class="mb-8">
        <h1 class="reveal-item is-visible font-display text-3xl font-bold tracking-tight text-(--color-fg) sm:text-4xl xl:text-5xl">
          {p.title}
        </h1>
        <p class="reveal-item is-visible mt-4 text-lg leading-relaxed text-(--color-muted)">
          {p.summary ?? p.description}
        </p>
        <div class="reveal-item is-visible mt-5 flex flex-wrap items-center gap-4 text-sm text-(--color-muted)">
          <span class="inline-flex items-center gap-1.5">
            <Calendar className="h-4 w-4" /> {fmtDate(p.pubDate)}
          </span>
          {p.category && (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-(--color-border) bg-(--color-bg) px-3 py-1 text-xs font-semibold text-(--color-fg)">
              <span class="h-1.5 w-1.5 rounded-full bg-(--color-accent)"></span>
              {p.category}
            </span>
          )}
        </div>
      </header>

      <img
        src={asset(p.coverImage)}
        alt={`Portada de ${p.title}`}
        width={1600}
        height={1000}
        class="reveal-item is-visible aspect-[8/5] w-full rounded-2xl object-cover"
      />

      {/* Tecnologías + enlaces externos */}
      <div class="reveal-item is-visible mt-8 flex flex-wrap items-center gap-3">
        <ul class="flex flex-wrap gap-2">
          {p.technologies.map((t) => (
            <li class="rounded-full bg-(--color-bg) px-2.5 py-1 text-xs font-medium text-(--color-muted) ring-1 ring-(--color-border)">
              {t}
            </li>
          ))}
        </ul>
        <div class="ml-auto flex items-center gap-4 text-sm">
          {p.githubUrl && (
            <a
              href={p.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 font-medium text-(--color-accent) hover:underline"
            >
              <Code2 className="h-4 w-4" /> Código
            </a>
          )}
          {p.demoUrl && (
            <a
              href={p.demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 font-medium text-(--color-accent) hover:underline"
            >
              <ExternalLink className="h-4 w-4" /> Demo
            </a>
          )}
        </div>
      </div>

      {/* Cuerpo markdown del proyecto */}
      <div
        class="prose-project reveal-item is-visible mt-10 max-w-none text-base leading-relaxed text-(--color-muted)"
      >
        <Content />
      </div>
    </article>

    {/* Volver al índice de proyectos */}
    <div class="mt-12">
      <a
        href={`${base}/proyectos/`}
        class="inline-flex items-center gap-2 rounded-full glass-pill px-5 py-2.5 text-sm font-medium text-(--color-fg) transition hover:-translate-y-0.5 hover:text-(--color-accent)"
      >
        <ArrowLeft className="h-4 w-4" /> Ver todos los proyectos
      </a>
    </div>
  </main>

  <Ticker
    items={['Python', 'Django', 'React', 'Astro', 'PyTorch', 'Deep Learning']}
    duration={32}
    solid
    class="mb-16"
  />
</Layout>